---
import { SITE } from '../data/site';

const services = [
  {
    image: '/images/services/tour-makoko.jpg',
    imageAlt: 'Traveller on a traditional boat in Makoko, Lagos floating village, with a local guide',
    title: 'Lagos Day Tour',
    subtitle: 'See the city with a local',
    description: 'Explore Lagos with Benjamin as your guide — markets, neighbourhoods, culture, food, art, beaches, and local life tailored to your interests.',
    cta: 'Ask about a Lagos tour',
    accent: 'nigeria-deep',
    learnMore: { href: '/lagos-private-guide/', label: 'Lagos private guide services' },
  },
  {
    image: '/images/services/tour-culture.jpg',
    imageAlt: 'Benjamin and a traveller posing at a cultural statue in Lagos',
    title: 'Culture, Food & Local Life',
    subtitle: 'Experience Nigeria beyond the surface',
    description: 'Discover Nigerian food, street life, music, markets, art, and everyday culture. No tourist script — just real local experience with Benjamin.',
    cta: 'Ask what is possible',
    accent: 'nigeria-clay',
  },
  {
    image: '/images/services/airport.jpg',
    imageAlt: 'Airport arrival and first day help in Lagos, Nigeria',
    title: 'Airport Pickup & First-Day Help',
    subtitle: 'Arrive with confidence',
    description: 'Benjamin can help with airport arrival, transport, settling in, SIM card advice, money exchange guidance, and first-day logistics in Lagos.',
    cta: 'Ask about arrival help',
    accent: 'nigeria-fresh',
  },
  {
    image: '/images/services/itinerary.jpg',
    imageAlt: 'Custom Nigeria itinerary planning with Benjamin',
    title: 'Custom Nigeria Itinerary',
    subtitle: 'Plan your trip around your interests',
    description: 'Tell Benjamin your travel dates and what you want to experience. He can help shape a realistic plan around your budget and time in Nigeria.',
    cta: 'Plan on WhatsApp',
    accent: 'nigeria-deep',
    learnMore: { href: '/things-to-do/', label: 'See things to do in Nigeria' },
  },
  {
    image: '/images/services/visa-invitation-letter.jpg',
    imageAlt: 'Travel documents and passport for visa invitation letter support',
    imagePosition: 'object-[center_30%]', // portrait image — crop to passport area. Photo: Taryn Elliott via Pexels — pexels.com/photo/5405596
    title: 'Visa Invitation Letter',
    subtitle: 'Support for your visa process',
    description: 'If you need a letter of invitation for your Nigeria visa application, Benjamin can help prepare one. Ask on WhatsApp what information is needed.',
    cta: 'Ask about visa letter support',
    accent: 'nigeria-clay',
    learnMore: { href: '/nigeria-visa-invitation-letter/', label: 'Nigeria visa invitation letter support' },
  },
];
---

<section id="tours" class="py-20 lg:py-28 bg-white" aria-labelledby="tours-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="adire-divider mx-auto mb-6"></div>
      <h2 id="tours-heading" class="section-heading mb-4">
        How Benjamin can help
      </h2>
      <p class="section-subheading mx-auto">
        Whether you need a full-day guide, airport help, a custom itinerary, or visa support — Benjamin offers flexible private guiding across Nigeria.
      </p>
    </div>

    <!-- Service cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <article class="card-base group flex flex-col" aria-label={s.title}>
          <!-- Image -->
          <div class="relative overflow-hidden aspect-[4/3]">
            <img
              src={s.image}
              alt={s.imageAlt}
              loading="lazy"
              class={`w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ${s.imagePosition ?? 'object-center'}`}
              onerror="this.onerror=null;this.src='/images/hero/hero.jpg';"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <!-- Subtitle pill -->
            <span class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm text-nigeria-deep text-xs font-semibold px-3 py-1 rounded-full">
              {s.subtitle}
            </span>
          </div>

          <!-- Content -->
          <div class="p-6 flex flex-col flex-1">
            <h3 class="font-display text-xl font-bold text-nigeria-charcoal mb-2">{s.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-5">{s.description}</p>
            <a
              href={SITE.whatsappUrl}
              aria-label={`${s.cta} — contact Benjamin on WhatsApp`}
              class="btn-whatsapp-sm self-start"
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {s.cta}
            </a>
            {s.learnMore && (
              <a
                href={s.learnMore.href}
                class="mt-3 inline-flex items-center gap-1 text-nigeria-deep font-semibold text-sm hover:underline self-start"
              >
                {s.learnMore.label}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
