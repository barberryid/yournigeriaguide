---
import { SITE } from '../data/site';
---

<section id="pricing" class="py-20 lg:py-28 bg-nigeria-sand relative overflow-hidden" aria-labelledby="pricing-heading">
  <!-- Adire texture overlay -->
  <div class="absolute inset-0 bg-adire-pattern opacity-30 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="adire-divider mx-auto mb-6"></div>
      <h2 id="pricing-heading" class="section-heading mb-4">
        Clear daily pricing
      </h2>
      <p class="section-subheading mx-auto">
        No hidden fees. No surprises. Benjamin's guide fee is straightforward.
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 items-start justify-center">

      <!-- Main price card -->
      <div class="w-full lg:max-w-md">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
          <!-- Green header -->
          <div class="bg-nigeria-deep px-8 py-10 text-center relative overflow-hidden">
            <div class="absolute inset-0 bg-adire-pattern opacity-20"></div>
            <div class="relative">
              <p class="text-nigeria-sand text-sm font-semibold uppercase tracking-widest mb-3">Guide fee</p>
              <p class="font-display text-6xl font-bold text-white mb-1">
                USD 50
              </p>
              <p class="text-white/70 text-lg font-medium">per day</p>
            </div>
          </div>

          <!-- Details -->
          <div class="px-8 py-8">
            <p class="text-gray-600 leading-relaxed mb-6 text-base">
              The guide fee is <strong class="text-nigeria-charcoal">USD 50 per day</strong>. This covers Benjamin's guiding service for the full day. Your own extra costs are not included.
            </p>

            <!-- What's included -->
            <div class="mb-6">
              <p class="font-semibold text-nigeria-charcoal text-sm uppercase tracking-wide mb-3">What's included</p>
              {[
                'Benjamin\'s time and local guiding',
                'Local knowledge and route planning',
                'Language help and local navigation',
                'WhatsApp contact before and during the trip',
              ].map(item => (
                <div class="flex items-start gap-3 mb-2">
                  <svg class="w-5 h-5 text-nigeria-fresh flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-gray-600 text-sm">{item}</span>
                </div>
              ))}
            </div>

            <!-- What's extra -->
            <div class="mb-8">
              <p class="font-semibold text-nigeria-charcoal text-sm uppercase tracking-wide mb-3">Extra costs (not included)</p>
              {[
                'Transport (local rides, Bolt, buses)',
                'Meals and drinks',
                'Entrance fees for sites',
                'Accommodation',
                'Special activities or events',
              ].map(item => (
                <div class="flex items-start gap-3 mb-2">
                  <svg class="w-5 h-5 text-nigeria-clay flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                  <span class="text-gray-500 text-sm">{item}</span>
                </div>
              ))}
            </div>

            <a
              href={SITE.whatsappUrl}
              aria-label="Check availability with Benjamin on WhatsApp"
              class="btn-whatsapp w-full justify-center text-base py-4"
            >
              <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Check availability on WhatsApp
            </a>
          </div>
        </div>
      </div>

      <!-- Right column: tips + clarity box -->
      <div class="w-full lg:max-w-md flex flex-col gap-6">

        <!-- Before you book tip -->
        <div class="bg-white rounded-2xl p-6 shadow-card border-l-4 border-nigeria-clay">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-nigeria-clay flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
              <p class="font-semibold text-nigeria-charcoal mb-2">Before confirming, ask Benjamin:</p>
              <ul class="text-gray-500 text-sm space-y-1 list-disc list-inside">
                <li>What is included in the guide fee</li>
                <li>What extra costs you should budget for transport</li>
                <li>Entry fees for any sites you want to visit</li>
                <li>Food and any special plans</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- How to message -->
        <div class="bg-nigeria-deep rounded-2xl p-6 shadow-card text-white">
          <p class="font-display text-lg font-bold mb-3">Message Benjamin with your dates</p>
          <p class="text-white/75 text-sm leading-relaxed mb-5">
            Tell Benjamin your dates and what you want to see. He can explain what extra costs to expect for transport, entry fees, food, and any special plans.
          </p>
          <div class="text-sm text-white/60 space-y-2 mb-5">
            {[
              'Your travel dates',
              'Number of travellers',
              'Where you arrive in Nigeria',
              'What you want to see or do',
            ].map(item => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-nigeria-whatsapp flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
                {item}
              </div>
            ))}
          </div>
          <a
            href={SITE.whatsappUrl}
            aria-label="Message Benjamin on WhatsApp with your travel dates"
            class="inline-flex items-center gap-2 bg-nigeria-whatsapp text-white font-semibold px-5 py-3 rounded-full shadow-whatsapp hover:bg-green-400 transition-all duration-200 text-sm w-full justify-center"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Tell Benjamin your dates
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
