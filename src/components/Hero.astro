---
import { SITE } from '../data/site';
---

<section class="relative min-h-screen flex flex-col justify-end overflow-hidden" aria-label="Hero section">
  <!-- Hero image: Benjamin on a Lagos rooftop, golden hour -->
  <img
    src="/images/hero/benjamin-rooftop.jpg"
    alt="Benjamin, private guide in Nigeria, smiling on a Lagos rooftop at sunset"
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover object-[center_20%]"
  />

  <!-- Gradient rises from the bottom so the face stays visible at top,
       text at bottom sits on a dark base for readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-nigeria-charcoal/90 via-nigeria-charcoal/40 to-nigeria-charcoal/10"></div>

  <!-- Adire-inspired pattern overlay -->
  <div class="absolute inset-0 bg-adire-pattern opacity-15"></div>

  <!-- Content — pushed to bottom so Benjamin's face shows above -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-64 text-center w-full">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 text-sm font-medium px-4 py-2 rounded-full mb-6">
      <span class="w-2 h-2 rounded-full bg-nigeria-whatsapp animate-pulse-slow inline-block"></span>
      Independent local guide · Lagos, Nigeria
    </div>

    <!-- Headline -->
    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-5 max-w-4xl mx-auto">
      Your trusted private<br class="hidden sm:block" /> guide in Nigeria
    </h1>

    <!-- Subheading -->
    <p class="text-lg sm:text-xl text-white/85 leading-relaxed max-w-2xl mx-auto mb-8">
      Explore Lagos and Nigeria with Benjamin — a friendly local guide who helps visitors save money, move around confidently, and experience the country with local knowledge.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href={SITE.whatsappUrl}
        aria-label="Contact Benjamin on WhatsApp"
        class="btn-whatsapp text-base px-8 py-4 text-lg"
      >
        <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp Benjamin
      </a>
      <a
        href="#tours"
        class="inline-flex items-center gap-2 border-2 border-white/60 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/10 hover:border-white transition-all duration-200 text-lg"
      >
        See Tours &amp; Prices
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
      {[
        { icon: '📍', text: 'Local Nigerian guide' },
        { icon: '💵', text: 'USD 50 per day' },
        { icon: '💬', text: 'WhatsApp contact' },
        { icon: '📋', text: 'Visa letter support' },
      ].map(badge => (
        <div class="flex items-center gap-2 text-white/80 text-sm font-medium">
          <span aria-hidden="true">{badge.icon}</span>
          {badge.text}
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/40 animate-bounce-slow" aria-hidden="true">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
