---
import { SITE } from '../data/site';

const reviews = [
  {
    name: 'Dongyu L.',
    date: 'January 2025',
    photo: '/images/reviews/reviewer-asian.jpg',
    text: 'Benjamin was an excellent guide for my time in Lagos. He helped me navigate the city, visit Makoko, and explore local markets. His knowledge of the city and his friendly personality made the whole trip enjoyable and safe. I would highly recommend booking him.',
    location: 'Visited Lagos',
  },
  {
    name: 'Peter M.',
    date: 'November 2024',
    photo: '/images/reviews/reviewer-european.jpg',
    text: 'I had a great experience with Benjamin. He took me to places I would never have found on my own. He was punctual, communicative on WhatsApp before the trip, and genuinely helpful throughout the day. Worth every dollar.',
    location: 'Visited Lagos & surroundings',
  },
];
---

<section id="reviews" class="py-20 lg:py-28 bg-nigeria-cream" aria-labelledby="reviews-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="adire-divider mx-auto mb-6"></div>
      <h2 id="reviews-heading" class="section-heading mb-4">
        Traveller reviews
      </h2>
      <p class="section-subheading mx-auto">
        International visitors who have explored Nigeria with Benjamin.
      </p>
    </div>

    <!-- Review cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      {reviews.map(r => (
        <article class="card-base p-8" aria-label={`Review by ${r.name}`}>
          <!-- Stars -->
          <div class="flex gap-1 mb-5" aria-label="5 out of 5 stars">
            {Array(5).fill(0).map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-gray-600 leading-relaxed text-base mb-6 italic">
            "{r.text}"
          </blockquote>

          <!-- Reviewer -->
          <div class="flex items-center gap-4 pt-4 border-t border-gray-100">
            <img
              src={r.photo}
              alt={`Photo of ${r.name}`}
              loading="lazy"
              class="w-12 h-12 rounded-full object-cover object-top"
              onerror="this.onerror=null;this.style.display='none';"
            />
            <div>
              <p class="font-semibold text-nigeria-charcoal text-sm">{r.name}</p>
              <p class="text-gray-400 text-xs">{r.location} · {r.date}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA to ask for references -->
    <div class="text-center">
      <p class="text-gray-500 text-sm mb-4">Want more references from recent travellers?</p>
      <a
        href={SITE.whatsappUrl}
        aria-label="Ask Benjamin for recent traveller references on WhatsApp"
        class="btn-outline"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Ask Benjamin for recent references
      </a>
    </div>
  </div>
</section>
