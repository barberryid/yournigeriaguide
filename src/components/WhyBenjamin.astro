---
const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'Local knowledge',
    body: 'Benjamin helps visitors understand how Nigeria works on the ground — transport, prices, neighbourhoods, timing, safety, and local customs.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Save money',
    body: 'Avoid tourist overcharging and unnecessary costs. Benjamin helps you make practical choices for transport, food, sightseeing, and daily plans.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
    title: 'Clear communication',
    body: 'The easiest way to plan your trip is by WhatsApp. Send your dates, interests, and questions before you arrive.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
    title: 'Flexible private guiding',
    body: 'Plan a day in Lagos, a multi-day trip, airport help, market visits, cultural experiences, beaches, food, or custom sightseeing.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
    title: 'Visa invitation letter support',
    body: 'Benjamin can help arrange a letter of invitation for travellers who need support for their Nigeria visa process.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
    title: 'Friendly personal service',
    body: 'This is not a large anonymous tour company. You are contacting Benjamin directly — a real local who genuinely wants your Nigeria experience to be great.',
  },
];
---

<section id="why-benjamin" class="py-20 lg:py-28 bg-nigeria-cream" aria-labelledby="why-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="adire-divider mx-auto mb-6"></div>
      <h2 id="why-heading" class="section-heading mb-4">
        Why travel with Benjamin?
      </h2>
      <p class="section-subheading mx-auto">
        Planning a trip to Nigeria can feel complicated from outside the country. Benjamin helps you travel with confidence, local knowledge, and a friendly guide by your side.
      </p>
    </div>

    <!-- About block with photo -->
    <div class="flex flex-col lg:flex-row items-center gap-12 mb-20">
      <div class="lg:w-2/5">
        <div class="relative">
          <div class="absolute -inset-4 bg-adire-pattern opacity-30 rounded-3xl"></div>
          <img
            src="/images/about/benjamin.png"
            alt="Adebayo Benjamin, private guide in Nigeria"
            loading="lazy"
            class="relative w-full max-w-sm mx-auto rounded-2xl shadow-xl object-cover aspect-[3/4]"
          />
          <!-- Green accent card -->
          <div class="absolute -bottom-6 -right-4 bg-nigeria-deep text-white rounded-2xl p-4 shadow-xl">
            <p class="font-display text-2xl font-bold">5+</p>
            <p class="text-xs text-white/75 font-medium">Years guiding</p>
          </div>
        </div>
      </div>

      <div class="lg:w-3/5">
        <div class="adire-divider mb-6"></div>
        <h3 class="font-display text-2xl md:text-3xl font-bold text-nigeria-charcoal mb-4">
          Meet Benjamin — your guide in Nigeria
        </h3>
        <p class="text-gray-600 leading-relaxed mb-4 text-base">
          Your Nigeria Guide is a private guiding service for travellers visiting Lagos and Nigeria. Adebayo Benjamin is a local private guide based in Lagos who helps visitors plan realistic days on the ground, understand local transport, avoid common travel mistakes, and experience Nigerian culture with a friendly guide by their side.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6 text-base">
          Whether you need a Lagos day tour, help on arrival, local food and market visits, cultural experiences, beach trips, or a custom Nigeria itinerary, Benjamin can help you plan everything by WhatsApp before you arrive — from the moment you land to the day you leave.
        </p>
        <a
          href="https://wa.me/2349065102421?text=Hello%20Benjamin%2C%20I%20found%20Your%20Nigeria%20Guide%20online.%20I%20am%20interested%20in%20a%20guided%20trip%20in%20Nigeria.%20Can%20you%20help%20me%20plan%20it%3F"
          aria-label="Contact Benjamin on WhatsApp"
          class="btn-whatsapp"
        >
          <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Send Benjamin a message
        </a>
      </div>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(f => (
        <div class="card-base p-6 group">
          <div class="w-12 h-12 rounded-xl bg-nigeria-deep/10 text-nigeria-deep flex items-center justify-center mb-4 group-hover:bg-nigeria-deep group-hover:text-white transition-all duration-300" set:html={f.icon} />
          <h3 class="font-display text-lg font-semibold text-nigeria-charcoal mb-2">{f.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
